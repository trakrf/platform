# Backend Task Runner (TrakRF Platform)
# Uses fallback to inherit shared recipes from root justfile
set fallback := true

# Get database URLs from environment (loaded by direnv from .env.local)
pg_url_local := env("PG_URL_LOCAL", "")
pg_url_cloud := env("PG_URL_CLOUD", "")

# List all available recipes
default:
    @just --list

# Start Go development server with hot reload (backend on host → postgres in docker)
dev:
    @echo "🚀 Backend on host → postgres in docker (localhost:5432)"
    @env PG_URL="{{pg_url_local}}" air

# Cloud development with hot reload (backend on host → postgres in cloud)
dev-cloud:
    @echo "☁️  Backend on host → cloud postgres"
    @env PG_URL="{{pg_url_cloud}}" air

# Run without hot reload (for debugging)
dev-no-reload:
    @echo "🚀 Backend on host → postgres in docker (no hot reload)"
    @go build -o ./tmp/main . && env PG_URL="{{pg_url_local}}" ./tmp/main

# Alias for consistency
run: dev

# Lint Go code (formatting + static analysis)
lint: check-rls-guard
    go fmt ./...
    go vet ./...

# Run backend tests with verbose output
test *args:
    #!/usr/bin/env bash
    if [ -z "{{args}}" ]; then
        go test -v ./...
    else
        go test -v {{args}}
    fi

# Run tests with the integration build tag (needs live Postgres)
# -p 1 serializes packages: they share the trakrf_test DB name, so running
# concurrently causes migration / schema collisions.
test-integration *args:
    go test -tags=integration -p 1 -v {{args}}

# TRA-671: Run Schemathesis contract tests against an ephemeral schemathesis DB.
# Stands up TimescaleDB if not running, migrates trakrf_schemathesis, loads the
# contract-test seed, starts the backend with APP_ENV=test, mints an API key via
# /test/apikeys, runs schemathesis, and tears down. Idempotent — safe to re-run.
#
# Notes:
#   - Backend listens on 8081 to avoid clobbering a developer's running dev backend.
#   - APP_ENV=test (any value != "production") mounts the test handler.
#   - With set -euo pipefail, a non-zero schemathesis exit (findings) will fail
#     the recipe. That's correct gate behavior — the report is still written to
#     backend/contract-tests/.
test-contract:
    #!/usr/bin/env bash
    set -euo pipefail
    REPO_ROOT="$(git rev-parse --show-toplevel)"
    SCHEMA_DB="trakrf_schemathesis"
    PG_PASSWORD="${POSTGRES_PASSWORD:-postgres}"
    # URL-encode the password so chars like '#' don't get parsed as URL fragments
    PG_PASSWORD_ENC="$(python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$PG_PASSWORD")"
    PG_URL_ROOT="postgres://postgres:${PG_PASSWORD_ENC}@localhost:5432/postgres?sslmode=disable"
    export PG_URL_LOCAL="postgres://postgres:${PG_PASSWORD_ENC}@localhost:5432/${SCHEMA_DB}?sslmode=disable"

    cleanup() {
        if [ -n "${BACKEND_PID:-}" ]; then
            # go run spawns the compiled binary as a child — kill the child
            # (the actual listener) first, then the parent.
            pkill -P "$BACKEND_PID" 2>/dev/null || true
            kill "$BACKEND_PID" 2>/dev/null || true
        fi
    }
    trap cleanup EXIT

    # 1. Ensure timescaledb is up. Probe over the published TCP port from the
    # host — pg_isready inside the container can flip green a moment before
    # the docker port mapping starts accepting connections (CI cold-start race),
    # which would crash the first host-side psql call with "server closed the
    # connection unexpectedly".
    echo "🐳 Ensuring timescaledb is up..."
    docker compose -p platform -f "$REPO_ROOT/docker-compose.yaml" up -d timescaledb
    DB_READY=0
    for _ in {1..60}; do
        if PGPASSWORD="$PG_PASSWORD" psql -h localhost -p 5432 -U postgres -d postgres -c 'SELECT 1' >/dev/null 2>&1; then
            DB_READY=1
            break
        fi
        sleep 1
    done
    if [ "$DB_READY" -ne 1 ]; then
        echo "❌ timescaledb did not become ready within 60s" >&2
        exit 1
    fi

    # 2. (Re)create the contract-test DB. Terminate any lingering sessions
    # first (e.g. an interrupted prior run) so DROP DATABASE doesn't error.
    #
    # Pin search_path=trakrf,public at the database level (not on the connection
    # URL) so every connection — migrate, backend, psql for seeding — sees the
    # same path. Putting it on the URL via options=-c would break golang-migrate:
    # CURRENT_SCHEMA() returns 'public' on the first run (trakrf doesn't exist
    # yet) and 'trakrf' afterwards, putting schema_migrations in different
    # schemas across runs.
    echo "🗄  Recreating ${SCHEMA_DB}..."
    psql "$PG_URL_ROOT" -v ON_ERROR_STOP=1 -c \
        "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='${SCHEMA_DB}';" >/dev/null
    psql "$PG_URL_ROOT" -v ON_ERROR_STOP=1 -c "DROP DATABASE IF EXISTS ${SCHEMA_DB};"
    psql "$PG_URL_ROOT" -v ON_ERROR_STOP=1 -c "CREATE DATABASE ${SCHEMA_DB};"
    psql "$PG_URL_ROOT" -v ON_ERROR_STOP=1 -c \
        "ALTER DATABASE ${SCHEMA_DB} SET search_path = trakrf, public;"
    # Pre-create the trakrf schema so CURRENT_SCHEMA() on the first migrate
    # connection resolves to 'trakrf'. Without this the migration library would
    # put schema_migrations in 'public' on the first run, then look for it in
    # 'trakrf' on the second (backend startup re-runs migrations) — and apply
    # migration 1 again, which fails on "organization_seq already exists".
    psql "$PG_URL_LOCAL" -v ON_ERROR_STOP=1 -c "CREATE SCHEMA trakrf;"

    # 3. Migrate (PG_URL_LOCAL exported above, re-evaluated by just migrate)
    echo "🔄 Migrating ${SCHEMA_DB}..."
    just migrate

    # 4. Seed
    echo "🌱 Loading contract-test seed..."
    psql "$PG_URL_LOCAL" -v ON_ERROR_STOP=1 -f "$REPO_ROOT/backend/database/seeds/contract_test_seed.sql"

    # 5. Start backend in background on port 8081
    if ss -lnt 'sport = :8081' 2>/dev/null | grep -q ":8081"; then
        echo "❌ Port 8081 already in use — stop the other listener and retry" >&2
        exit 1
    fi
    echo "🚀 Starting backend on :8081 with APP_ENV=test..."
    PG_URL="$PG_URL_LOCAL" \
    APP_ENV=test \
    JWT_SECRET="${JWT_SECRET:-dev-secret-change-in-production}" \
    BACKEND_PORT=8081 \
        go run . >/tmp/trakrf-contract-backend.log 2>&1 &
    BACKEND_PID=$!

    # 6. Wait for /healthz
    echo "⏳ Waiting for /healthz..."
    READY=0
    for i in {1..60}; do
        if curl -sf http://localhost:8081/healthz > /dev/null 2>&1; then
            READY=1
            break
        fi
        sleep 1
    done
    if [ "$READY" -ne 1 ]; then
        echo "❌ Backend never became ready; tail of /tmp/trakrf-contract-backend.log:" >&2
        tail -50 /tmp/trakrf-contract-backend.log >&2 || true
        exit 1
    fi

    # 7. Mint API key
    echo "🔑 Minting contract-test API key..."
    KEY="$(curl -sf -X POST http://localhost:8081/test/apikeys \
        -H 'Content-Type: application/json' \
        -d '{"scopes":["assets:read","assets:write","locations:read","locations:write","tracking:read"]}' \
        | jq -r .token)"
    if [ -z "$KEY" ] || [ "$KEY" = "null" ]; then
        echo "❌ Failed to mint API key" >&2
        exit 1
    fi

    # 8. Run Schemathesis (docker, v4 CLI)
    #
    # The image runs as a non-root user; with a host bind mount the container
    # can't write report files unless we either chmod the host dir 0777 or
    # pin the container UID to the invoker. Pin --user to match: local devs
    # get reports owned by themselves, CI gets reports owned by the runner.
    echo "🧪 Running schemathesis..."
    mkdir -p "$REPO_ROOT/backend/contract-tests"
    chmod 0777 "$REPO_ROOT/backend/contract-tests"
    # Schemathesis exits non-zero when any *phase* shows ❌, which fires on
    # operation-level "Schema validation mismatch" warnings (operations that
    # 4xx most of their generated tests, e.g. DELETEs with FK-constrained
    # seed data) even when no individual test case actually failed
    # (TRA-678). The JUnit report is the truthful record of test outcomes;
    # if it lists zero failures/errors the run passes regardless of phase
    # status. `|| true` swallows the schemathesis exit and the JUnit guard
    # below restores hard-fail semantics on real findings.
    # TRA-681: `positive_data_acceptance` is disabled. The check enforces
    # "spec-compliant request must return 2xx/401/403/404/409/5xx" — i.e. a
    # 400 on a syntactically-valid body is always a failure. That model is
    # incompatible with two server-side semantic rules established in
    # design review:
    #
    #   * FK-existence (`fk_not_found`): a body that's spec-valid by shape
    #     can still reference an in-org row that does not exist. Industry
    #     precedent (Stripe, AWS, Atlassian) and the BB27 F2 design review
    #     pin this on 400 validation_error, not 409 — Schemathesis's
    #     accepted set explicitly excludes 400.
    #
    #   * Paired-key oneOf on GET filters: `?location_id=N&location_external_key=K`
    #     is spec-shaped (OpenAPI 3 can't encode query-param pair
    #     exclusivity) but server returns 400 ambiguous_fields per design.
    #
    # The POST-body oneOf case is encoded in the spec via
    # `not: required:[a,b]` (markMutuallyExclusiveFieldPairs) so the
    # generator no longer emits those payloads — that's the only one of
    # the three cases that *can* be expressed in the schema. The other
    # two need this check disabled to keep the gate honest.
    #
    # 2026-05-12 follow-up: `negative_data_rejection` is also disabled.
    # It fires false positives non-deterministically — same spec, same
    # backend, same Schemathesis version produces "API accepted
    # schema-violating request" on pull_request runs sometimes and not
    # others (caught on the first push-event run after PR #318 merged:
    # pull_request run on the identical tree passed, push-event run on
    # main produced 3 JUnit failures on /locations/{id}/ancestors,
    # /children, /descendants with `?offset=0`, an entirely
    # spec-compliant query).
    #
    # The check's failure_info reads: "Invalid component: in query —
    # violates `additionalProperties` at " with an empty path after
    # "at". That malformed message + non-reproducibility across runs
    # indicates a tooling bug, not a real spec drift. We've
    # corresponded the symmetric check (positive_data_acceptance) for
    # similar reasons; disabling negative_data_rejection makes the
    # gate's verdict stable across runs.
    #
    # Other checks (response_schema_conformance, not_a_server_error,
    # status_code_conformance, content_type_conformance,
    # response_headers_conformance, use_after_free,
    # ensure_resource_availability, ignored_auth, missing_required_header,
    # unsupported_method) remain on, so the meaningful regression-detection
    # signal is preserved.
    #
    # `--user "$(id -u):$(id -g)"` (so report files end up owned by the
    # host invoker / CI runner) leaves the container with no writable
    # home; the image's default `/app` cwd exposes that in two places:
    #
    #   * Hypothesis logs `HypothesisWarning: ... falling back to
    #     in-memory database` once per generated case
    #     (`/app/.hypothesis/examples` not writable).
    #   * TracecovHandler logs `PermissionError ... './schema-coverage.html'`
    #     at the end of the run when writing the optional coverage report.
    #
    # Both are non-fatal — Hypothesis works fine in memory and the
    # schema-coverage HTML is a nice-to-have we don't surface — but
    # together they bury the actual run output. Fixes:
    #
    #   * `-w /out` moves the container cwd to the mounted writable dir
    #     so the schema-coverage report writes cleanly alongside
    #     junit/har/ndjson rather than blowing up TracecovHandler.
    #   * `--tmpfs /app/.hypothesis` gives Hypothesis the writable cache
    #     directory it asks for. `--generation-deterministic` already
    #     means examples never persist across runs (the tmpfs evaporates
    #     with the container), but having the directory exist lets the
    #     library initialize cleanly instead of firing
    #     HypothesisWarning once per generated test case. We don't use
    #     `--generation-database=none` because Schemathesis rejects it
    #     with `--generation-deterministic` (the two flags express the
    #     same intent and are mutually exclusive at the CLI).
    docker run --rm --network host \
        --user "$(id -u):$(id -g)" \
        -w /out \
        --tmpfs /app/.hypothesis:uid=$(id -u),gid=$(id -g) \
        -v "$REPO_ROOT/docs/api/openapi.public.yaml:/spec.yaml:ro" \
        -v "$REPO_ROOT/backend/contract-tests:/out" \
        schemathesis/schemathesis:4.18.2 \
        run \
        --checks=all \
        --exclude-checks=positive_data_acceptance,negative_data_rejection \
        --warnings=off \
        --suppress-health-check=all \
        --generation-deterministic \
        --url http://localhost:8081 \
        --header "Authorization: Bearer ${KEY}" \
        --report=junit,har,ndjson \
        --report-dir=/out \
        /spec.yaml || true

    # Authoritative pass/fail: scan the latest JUnit for failures/errors.
    JUNIT="$(ls -t "$REPO_ROOT/backend/contract-tests"/junit-*.xml 2>/dev/null | head -1)"
    if [ -z "$JUNIT" ]; then
        echo "❌ schemathesis produced no JUnit report" >&2
        exit 1
    fi
    if grep -qE '<(failure|error) ' "$JUNIT"; then
        echo "❌ schemathesis JUnit reports failures/errors — see $JUNIT" >&2
        exit 1
    fi
    echo "✅ schemathesis: 0 failures, 0 errors (JUnit: $JUNIT)"

# Run tests with race detection
test-race:
    go test -race ./...

# Run tests with coverage report
test-coverage:
    go test -cover ./...

# Resync vendor directory with go.mod
vendor:
    go mod vendor

# Build backend binary with version + build metadata injection (regenerates
# internal spec first). commit, tag, and build_time surface at /health so
# operators can tell which SHA is running — see TRA-481.
build: api-spec
    #!/usr/bin/env bash
    set -euo pipefail
    COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    TAG=$(git describe --tags --always --dirty 2>/dev/null || echo "dev")
    BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    go build -ldflags "-X main.version=0.1.0-dev -X main.commit=${COMMIT} -X main.tag=${TAG} -X main.buildTime=${BUILD_TIME}" -o bin/trakrf .

# Generate OpenAPI 3.0 specs (public → docs/api/ + embedded; internal → embedded only)
api-spec:
    @# swag's --parseDependency walks main.go, which has //go:embed frontend/dist.
    @# Without a real or stub file there, swag falls back to fully-qualified Go
    @# package names in schema definitions (~700 lines of churn). See TRA-505.
    @[ -e frontend/dist/index.html ] || (mkdir -p frontend/dist && touch frontend/dist/index.html)
    @echo "📚 Generating OpenAPI 3.0 specs..."
    swag init -g main.go --parseDependency --parseInternal -o docs
    @mkdir -p internal/handlers/swaggerspec ../docs/api
    go run ./internal/tools/apispec \
        --in docs/swagger.json \
        --public-out ../docs/api/openapi.public \
        --internal-out internal/handlers/swaggerspec/openapi.internal
    @cp ../docs/api/openapi.public.json internal/handlers/swaggerspec/openapi.public.json
    @cp ../docs/api/openapi.public.yaml internal/handlers/swaggerspec/openapi.public.yaml
    @echo "✅ Public spec:   docs/api/openapi.public.{json,yaml}  (committed) + swaggerspec/ (gitignored, embedded)"
    @echo "✅ Internal spec: backend/internal/handlers/swaggerspec/openapi.internal.{json,yaml}  (gitignored, embedded)"

# Legacy alias retained for muscle memory
swagger: api-spec

# Smoke test - verifies binary starts without panic (uses PG_URL_LOCAL for host → docker)
smoke-test:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "🔥 Running smoke test..."
    just build
    echo "Starting server with 5s timeout..."
    export PG_URL="{{pg_url_local}}"
    timeout 5s ./bin/trakrf > /tmp/trakrf-smoke.log 2>&1 & SERVER_PID=$!
    sleep 2
    echo "Testing /healthz endpoint..."
    if curl -f http://localhost:8080/healthz > /dev/null 2>&1; then
    echo "✅ Smoke test passed"
    kill $SERVER_PID 2>/dev/null || true
    else
    echo "❌ Smoke test failed"
    cat /tmp/trakrf-smoke.log
    kill $SERVER_PID 2>/dev/null || true
    exit 1
    fi

# Lint the public OpenAPI spec with Redocly CLI (uses pnpm). Mirrors CI:
# runs from the repo root so redocly auto-discovers ../redocly.yaml; the
# config there extends `recommended` and overrides repo-specific rules.
api-lint:
    cd .. && pnpm --package=@redocly/cli dlx redocly lint docs/api/openapi.public.yaml --extends=recommended

# TRA-455: Fail if pool.Query/Exec/Begin reappears in non-test storage code
# on RLS-protected tables. Coarse grep-based guard; a proper analyzer is a
# separate follow-up ticket.
#
# Scoped to the five RLS-protected storage files only — apikeys, organizations,
# users, invitations, etc. legitimately use raw pool (their tables are not
# RLS-protected). reports.go hits asset_scans (not RLS-protected). transactions.go
# defines WithOrgTx itself. *_test.go files may use raw pool for fixtures.
check-rls-guard:
    #!/usr/bin/env bash
    set -e
    RLS_FILES="internal/storage/assets.go internal/storage/locations.go internal/storage/inventory.go internal/storage/tags.go internal/storage/bulk_import_jobs.go"
    RESULT=$(grep -n 's\.pool\.\(Query\|Exec\|Begin\)' $RLS_FILES || true)
    FILTERED=$(echo "$RESULT" | grep -v '^$' || true)
    if [ -n "$FILTERED" ]; then
        echo "ERROR: s.pool.Query/Exec/Begin found in RLS-protected storage code. Wrap in WithOrgTx."
        echo "See TRA-455. Offenders:"
        echo "$FILTERED"
        exit 1
    fi
    echo "✓ check-rls-guard: clean"

# Run all backend validation checks
# Note: api-spec is NOT in this chain — swag's output depends on the local Go/swag
# build cache in ways that differ between dev machines and CI. The committed spec
# is whatever CI produces; local regeneration may legitimately diverge without
# indicating stale annotations. The drift check runs only in CI (api-spec.yml).
validate: api-lint lint test build smoke-test

# Shell access
shell:
    docker compose exec backend sh

# ============================================================================
# Database Migrations
# ============================================================================

# Run database migrations using the embedded set (./server migrate)
migrate:
    @echo "🔄 Running database migrations..."
    @env PG_URL="{{pg_url_local}}" go run . migrate
    @echo "✅ Migrations complete"

# Alias for consistency
migrate-up: migrate

# Roll back last migration
migrate-down:
    @echo "⏪ Rolling back last migration..."
    docker compose exec backend sh -c 'migrate -path /app/migrations -database "$PG_URL" down 1'
    @echo "✅ Rollback complete"

# Show current migration version
migrate-status:
    @echo "📊 Migration status:"
    docker compose exec backend sh -c 'migrate -path /app/migrations -database "$PG_URL" version'

# Create new migration file
migrate-create name:
    @echo "📝 Creating new migration: {{name}}"
    docker compose exec backend sh -c 'migrate create -ext sql -dir /app/migrations -seq {{name}}'

# Force migration to specific version (dangerous)
migrate-force version:
    @echo "⚠️  Forcing migration version to {{version}}"
    docker compose exec backend sh -c 'migrate -path /app/migrations -database "$PG_URL" force {{version}}'
