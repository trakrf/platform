#!/usr/bin/env bash
# Install (root): cp to /usr/lib/systemd/system-sleep/trakrf-resume ; chmod 755
# TRA-989: on resume from suspend, proactively clear any rootlessport forward wedge for the
# lingering demo user (lid-open = de-facto power-up). Replace WATCHDOG_USER (brick: mike).
WATCHDOG_USER=WATCHDOG_USER
case "$1/$2" in
  post/*)   # $1=post means waking back up
    uid=$(id -u "$WATCHDOG_USER") || exit 0
    su - "$WATCHDOG_USER" -c "XDG_RUNTIME_DIR=/run/user/$uid /srv/trakrf/scripts/rootlessport-watchdog.sh --on-resume" || true
    ;;
esac
