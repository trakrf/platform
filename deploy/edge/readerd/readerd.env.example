# TrakRF reader-control daemon (server readerd) environment.
# Copy to /opt/trakrf/readerd.env on the reader and fill in READER_API_PASS.
# Everything else is optional: the daemon auto-discovers its broker config and
# event from the reader's own EmbeddedGlassFish CloudServer/EventList files.

# --- Reader localhost HTTP API (required secret) ----------------------------
# Password for the reader's servlet API. REQUIRED.
READER_API_PASS=changeme

# Base URL of the reader's HTTP API. The daemon runs ON the reader, so this is
# localhost by default. Override only for off-box testing.
#READER_API_URL=http://localhost

# Reader API username. Default: root.
#READER_API_USER=root

# --- Broker auto-discovery overrides ----------------------------------------
# By default the daemon reads the reader's CloudServer config and selects the
# MQTT entry named below, deriving broker URL / CA cert / base topic / RPC
# client id from it. Override the selected CloudServer name here.
#READERD_CLOUDSERVER_ID=TrakRF MQTT

# The reader event bound to the active inventory profile. Auto-discovered as the
# single enabled event in EventListCS463 if unset.
#READERD_EVENT_ID=

# Physical antenna port count (CS463 = 4).
#READERD_ANTENNA_COUNT=4

# --- Explicit broker override (bypasses CloudServer auto-discovery) ----------
# Set READERD_BROKER_URL to skip auto-discovery entirely; when set, the four
# vars below are used verbatim instead of the reader's CloudServer entry.
#READERD_BROKER_URL=mqtts://user:pass@broker.example.com:8883
#READERD_BASE_TOPIC=acme-org/cs463-01
#READERD_CA_CERT=/opt/EmbeddedGlassFish/cert/CloudServer/TrakRF MQTT/ca.pem
#READERD_RPC_CLIENT_ID=cs463-01-rpc
