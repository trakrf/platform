# trakrf mqtt-rpcd environment (copy to /opt/trakrf/mqtt-rpcd.env on the reader)

# Reader localhost HTTP API credentials (the daemon runs ON the reader).
READER_API_PASS=CHANGEME            # required (CS463 root API password)
# READER_API_URL=http://localhost   # optional (default)
# READER_API_USER=root              # optional (default)

# Broker: auto-discovered from the reader's own CloudServer config by default.
# READERD_CLOUDSERVER_ID=TrakRF MQTT   # which CloudServer entry to reuse (default)
# READERD_EVENT_ID=                    # event to re-arm after a write (default: the enabled event)
# READERD_ANTENNA_COUNT=4

# Explicit broker overrides (bypass CloudServer auto-discovery):
# READERD_BROKER_URL=mqtts://user:pass@host:8883
# READERD_BASE_TOPIC=trakrf.id/cs463-212
# READERD_CA_CERT=/path/to/ca.pem
# READERD_RPC_CLIENT_ID=cs463-212-rpc
