# Cloudflare Tunnel token for the demo box (TRA-957).
# Managed by trakrf/infra Terraform — copy this file to cloudflared.env and set the real value.
# cloudflared reads TUNNEL_TOKEN natively; no other vars belong here (keeps DB/JWT secrets out
# of the tunnel sidecar). cloudflared.env is gitignored.
TUNNEL_TOKEN=CHANGEME
